<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.FitTrack" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#0A0A0F</item>
        <item name="android:navigationBarColor">#0A0A0F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.FitTrack.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.FitTrack</item>
    </style>
</resources>
